{
  "name": "frontend",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "NODE_OPTIONS=\"--max-old-space-size=4096\" nuxt build",
    "dev": "nuxt dev",
    "lint": "eslint app --ext .ts,.vue --quiet --rule \"no-undef: off\"",
    "type-check": "nuxt typecheck",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "generate": "nuxt generate",
    "generate:api": "openapi-ts --input http://localhost:3000/api/swagger.json --output packages/shared-api",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1",
    "@nuxt/ui": "^4.7.1",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.3.0",
    "@vueuse/integrations": "^14.3.0",
    "date-fns": "^4.1.0",
    "nuxt": "^4.3.1",
    "pinia": "^3.0.4",
    "sortablejs": "^1.15.7",
    "swiper": "^11.0.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.87.0",
    "@iconify-json/lucide": "^1.2.105",
    "@pinia/nuxt": "^0.11.3",
    "@playwright/test": "^1.57.0",
    "@types/sortablejs": "^1.15.9",
    "@vee-validate/nuxt": "^4.15.1",
    "@vite-pwa/nuxt": "^1.1.1",
    "sharp": "^0.34.5",
    "vitest": "^4.0.16",
    "zod": "^3.24.0"
  }
}
